# ── Twilio ──────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp sandbox number (keep as-is for sandbox testing)
# For production: replace with your approved WhatsApp Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Phone country code ───────────────────────────────────────────────
# Used to convert local numbers (e.g. 077XXXXXXXX) to international format
# Yemen: +967 | Iraq: +964 | Saudi: +966 | Jordan: +962
PHONE_COUNTRY_CODE=+967

# ── Firebase ─────────────────────────────────────────────────────────
# Your Realtime Database URL (from Firebase console)
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# Path to your Firebase service account key JSON file
# Download from: Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Server ───────────────────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────
# Origins allowed to call this backend (comma-separated)
# Use * for local dev, or your deployed domain for production
ALLOWED_ORIGINS=*
